{
  "version": 2,
  "builds": [
    {
      "src": "backEnd/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontEnd/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backEnd/server.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
